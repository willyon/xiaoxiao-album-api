# 桌面端运行环境模板（安全、非敏感默认值）。
# 本文件仅用于文档说明/参考。
# Electron 打包运行时应由主进程在 spawn(env) 时注入这些变量。

# ---- 核心运行配置 ----
NODE_ENV=production
DESKTOP_LOCAL_MODE=true
DESKTOP_LOCAL_USER_EMAIL=local_user@xiaoxiao-album.com

# ---- 数据路径（通常由 Electron 主进程注入） ----
# API_WORKDIR=/path/to/userData
# DATABASE_PATH=/path/to/userData/database.db
# API_BASE_URL_LOCAL=http://127.0.0.1:3000

# ---- 存储策略 ----
STORAGE_TYPE=local
UPLOADS_DIR=storage-local/upload
FAILED_MEDIA_DIR=storage-local/processing/failed
PROCESSED_ORIGINAL_MEDIA_DIR=storage-local/processed/original
PROCESSED_HIGH_RES_MEDIA_DIR=storage-local/processed/highres
PROCESSED_THUMBNAIL_MEDIA_DIR=storage-local/processed/thumbnail

# ---- Redis 配置 ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# ---- ffmpeg / ffprobe 配置 ----
# 当 ffmpeg 打进 build-resources 后，应由 Electron 主进程注入运行时绝对路径。
# FFMPEG_PATH=/absolute/path/to/ffmpeg
# FFPROBE_PATH=/absolute/path/to/ffprobe

# ---- 可选：AI / 队列调优 ----
# PYTHON_SERVICE_URL=http://127.0.0.1:5001
# AI_DEVICE=auto
# AI_MAX_CONCURRENCY=1
# QUEUE_JOB_ATTEMPTS=3
# QUEUE_JOB_BACKOFF_DELAY=2000
# MEDIA_UPLOAD_WORKER_CONCURRENCY=1
# MEDIA_META_WORKER_CONCURRENCY=1
# MEDIA_ANALYSIS_WORKER_CONCURRENCY=1
