# 复制为 .env 后按需修改（示例，非完整业务配置）
# 完整键名可参考仓库内 .env 或各服务 README

PORT=3000
NODE_ENV=development

# 批量导出 ZIP 单次最多媒体条数（未设置时由 exportService 内默认值）
# EXPORT_BATCH_MAX=5000

# 桌面本地模式：仅当值为 true（不区分大小写）时启用；与 desktop-bootstrap 闸门一致
DESKTOP_LOCAL_MODE=false

# 桌面静默登录：`DESKTOP_LOCAL_USER_EMAIL`（库中已激活用户）在实现 bootstrap 时配置；access JWT 无 exp，见路线图 §9.2.1
